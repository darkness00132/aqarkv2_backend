        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/revokeAll": {
      "delete": {
        "tags": [
          "Auth"
        ],
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Users/me": {
      "get": {
        "tags": [
          "Users"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AdDTO": {
        "required": [
          "adType",
          "cityName",
          "createdAt",
          "description",
          "governorateName",
          "images",
          "price",
          "propertyAddress",
          "propertyType",
          "space",
          "title",
          "user"
        ],
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "rooms": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "space": {
            "type": "number",
            "format": "double"
          },
          "price": {
            "type": "integer",
            "format": "int32"
          },
          "propertyAddress": {
            "type": "string",
            "nullable": true
          },
          "adType": {
            "type": "string",
            "nullable": true
          },
          "propertyType": {
            "type": "string",
            "nullable": true
          },
          "user": {
            "$ref": "#/components/schemas/PublicUser"
          },
          "governorateName": {
            "type": "string",
            "nullable": true
          },
          "cityName": {
            "type": "string",
            "nullable": true
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageDTO"
            },
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "AdListItemDTO": {
        "required": [
          "adType",
          "cityName",
          "coverImage",
          "createdAt",
          "governorateName",
          "price",
          "propertyType",
          "slug",
          "space",
          "title",
          "user"
        ],
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "rooms": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "space": {
            "type": "number",
            "format": "double"
          },
          "price": {
            "type": "integer",
            "format": "int32"
          },
          "adType": {
            "type": "string",
            "nullable": true
          },
          "propertyType": {
            "type": "string",
            "nullable": true
          },
          "governorateName": {
            "type": "string",
            "nullable": true
          },
          "cityName": {
            "type": "string",
            "nullable": true
          },
          "user": {
            "$ref": "#/components/schemas/PublicUser"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "coverImage": {
            "$ref": "#/components/schemas/ImageDTO"
          }
        },
        "additionalProperties": false
      },
      "AdType": {
        "enum": [
          1,
          2
        ],
        "type": "integer",
        "format": "int32"
      },
      "CompleteProfileDTO": {
        "required": [
          "phoneNumber",
          "role"
        ],
        "type": "object",
        "properties": {
          "phoneNumber": {
            "minLength": 1,
            "pattern": "^\\+?[1-9]\\d{1,14}$",
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/publicRoles"
          }
        },
        "additionalProperties": false
      },
      "ImageDTO": {
        "required": [
          "url"
        ],
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginDTO": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 6,
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*\\W).+$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PropertyType": {
        "enum": [
          1,
          2,
          3,
          4,
          5,
          6,
          7,
          8
        ],
        "type": "integer",
        "format": "int32"
      },
      "PublicUser": {
        "required": [
          "name",
          "phoneNumber",
          "slug"
        ],
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "phoneNumber": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegisterDTO": {
        "required": [
          "email",
          "name",
          "password",
          "phoneNumber",
          "role"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 0,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "phoneNumber": {
            "minLength": 1,
            "pattern": "^\\+?[1-9]\\d{1,14}$",
            "type": "string"
          },
          "password": {
            "minLength": 6,
            "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*\\W).+$",
            "type": "string"
          },
          "role": {
            "$ref": "#/components/schemas/publicRoles"
          }
        },
        "additionalProperties": false
      },
      "ResetPasswordDTO": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "token": {
            "type": "string",
            "nullable": true
          },
          "newPassword": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "publicRoles": {
        "enum": [
          1,
          2
        ],
        "type": "integer",
        "format": "int32"
      }
    }
  },
  "tags": [
    {
      "name": "Ads"
    },
    {
      "name": "Auth"
    },
    {
      "name": "Users"
    }
  ]
}