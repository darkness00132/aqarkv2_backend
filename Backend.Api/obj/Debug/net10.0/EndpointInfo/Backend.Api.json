{
  "openapi": "3.0.4",
  "info": {
    "title": "Backend.Api",
    "version": "1.0"
  },
  "paths": {
    "/api/Ads/all": {
      "get": {
        "tags": [
          "Ads"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AdListItemDTO"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AdListItemDTO"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AdListItemDTO"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/Ads/{id}": {
      "get": {
        "tags": [
          "Ads"
        ],
        "parameters": [
          {
            "name": "slug",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/AdDTO"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdDTO"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/AdDTO"
                }
              }
            }
          }
        }
      }
    },
    "/api/Ads/create": {
      "post": {
        "tags": [
          "Ads"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "AdType",
                  "CityId",
                  "Description",
                  "GovernorateId",
                  "Images",
                  "Price",
                  "PropertyAddress",
                  "PropertyType",
                  "Space",
                  "Title"
                ],
                "type": "object",
                "properties": {
                  "Title": {
                    "type": "string"
                  },
                  "Description": {
                    "type": "string"
                  },
                  "Rooms": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "Space": {
                    "type": "number",
                    "format": "double"
                  },
                  "Price": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "PropertyAddress": {
                    "type": "string"
                  },
                  "AdType": {
                    "$ref": "#/components/schemas/AdType"
                  },
                  "PropertyType": {
                    "$ref": "#/components/schemas/PropertyType"
                  },
                  "GovernorateId": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "CityId": {
                    "type": "integer",
                    "format": "int32"
                  },
                  "Images": {
                    "maxItems": 5,
                    "minItems": 1,
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  }
                }
              },
              "encoding": {
                "Title": {
                  "style": "form"
                },
                "Description": {
                  "style": "form"
                },
                "Rooms": {
                  "style": "form"
                },
                "Space": {
                  "style": "form"
                },
                "Price": {
                  "style": "form"
                },
                "PropertyAddress": {
                  "style": "form"
                },
                "AdType": {
                  "style": "form"
                },
                "PropertyType": {
                  "style": "form"
                },
                "GovernorateId": {
                  "style": "form"
                },
                "CityId": {
                  "style": "form"
                },
                "Images": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/google": {
      "get": {
        "tags": [
